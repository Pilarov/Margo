# Required — Postgres with pgvector extension enabled
DATABASE_URL=postgresql://retaindb:retaindb@localhost:5432/retaindb

# Optional — leave blank for open access (fine for localhost)
RETAINDB_API_KEY=

# Optional — enables OpenAI embeddings. Without it, a local BGE model is used.
OPENAI_API_KEY=

# Optional — LLM used to extract memories from conversations (default: gpt-4o-mini)
EXTRACTION_MODEL=gpt-4o-mini

# Optional
PORT=3000
DISABLE_SCHEDULER=false

# ── Embedding ──────────────────────────────────────────────────────────────
# Mode: openai | gemini | local | hybrid | remote | workers (default: remote)
#   openai  — OpenAI text-embedding-3-small (1024-dim)
#   gemini  — Google text-embedding-004 (768-dim, needs GOOGLE_API_KEY)
#   local   — BGE-large in-process via Transformers.js
#   hybrid  — local for small batches, OpenAI for large batches
#   remote  — custom inference service (EMBEDDING_INFERENCE_BASE_URL)
#   workers — alias for remote
# EMBEDDING_MODE=remote

# Model for standalone embedding-server (default: Xenova/bge-large-en-v1.5)
# EMBEDDING_MODEL=Xenova/bge-large-en-v1.5

# Remote inference service URLs (highest to lowest priority)
# EMBEDDING_INFERENCE_BASE_URL=http://localhost:8080
# EMBEDDING_BASE_URL=
# INFERENCE_BASE_URL=
# INFERENCE_API_URL=

# Remote inference auth
# INFERENCE_API_KEY=
# RETAINDB_INFERENCE_KEY=

# Remote inference timeout in ms (default: 2500)
# INFERENCE_TIMEOUT_MS=2500

# If true, embedding fails when remote is unreachable (default: false)
# REMOTE_INFERENCE_REQUIRED=false

# Batch size above which OpenAI/Gemini is forced (default: 20)
# LARGE_BATCH_THRESHOLD=20

# Embedding-server limits (default: maxBatch=64, maxConcurrency=2)
# EMBEDDING_MAX_BATCH_SIZE=64
# EMBEDDING_MAX_CONCURRENCY=2

# Persistent embedding cache file path (default: .embedding-cache.json)
# EMBEDDING_CACHE_FILE=.embedding-cache.json

# Gemini embedding dimensions, max 768 (default: 768)
# GEMINI_EMBEDDING_DIMENSIONS=768

# Google API key (required for EMBEDDING_MODE=gemini)
# GOOGLE_API_KEY=

# ── Reranking ──────────────────────────────────────────────────────────────
# Strategy: balanced | cross-encoder | llm (default: balanced)
#   balanced       — cross-encoder + optional LLM guard for low-confidence
#   cross-encoder  — local BGE-reranker-large only
#   llm            — gpt-4o-mini based reranking
# RERANK_MODE=balanced

# Provider: local | remote (default: local)
#   local  — in-process cross-encoder or LLM
#   remote — external HTTP service (RERANK_INFERENCE_BASE_URL)
# RERANK_PROVIDER=local

# Remote reranking service URLs (highest to lowest priority)
# RERANK_INFERENCE_BASE_URL=http://localhost:8080
# RERANK_BASE_URL=
# INFERENCE_BASE_URL=
# INFERENCE_API_URL=

# Enable LLM fallback in balanced mode (default: false)
# LLM_RERANK_ENABLED=false

# Total reranking time budget in ms (default: 90)
# RERANK_BUDGET_MS=90

# Minimum budget remaining for LLM fallback in ms (default: 75)
# LLM_RERANK_MIN_BUDGET_MS=75

# Max candidates sent to LLM reranker (default: 5)
# LLM_RERANK_MAX_CANDIDATES=5

# Max tokens for LLM reranking calls — increase for reasoning models (DeepSeek: ≥500)
# LLM_RERANK_MAX_TOKENS=200

# Max tokens for LLM extraction calls — increase for reasoning models (DeepSeek: ≥800)
# LLM_EXTRACTION_MAX_TOKENS=800

# Max candidates considered for reranking (default: 20)
# MAX_RERANK_CANDIDATES=20

# ── Local Runtime ──────────────────────────────────────────────────────────
# Embedding provider: hash | local-transformers (default: hash)
#   hash               — SHA-256 pseudo-embeddings (fast, no deps)
#   local-transformers — @xenova/transformers model
# RETAINDB_EMBEDDING_PROVIDER=hash

# Model for local transformers (default: Xenova/all-MiniLM-L6-v2)
# RETAINDB_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
