# Required — Postgres with pgvector extension enabled
DATABASE_URL=postgresql://retaindb:retaindb@localhost:5432/retaindb

# Optional — leave blank for open access (fine for localhost)
RETAINDB_API_KEY=

# Optional — enables OpenAI embeddings. Without it, a local BGE model is used.
OPENAI_API_KEY=

# Optional — LLM used to extract memories from conversations (default: gpt-4o-mini)
EXTRACTION_MODEL=gpt-4o-mini

# Optional
PORT=3000
DISABLE_SCHEDULER=false
